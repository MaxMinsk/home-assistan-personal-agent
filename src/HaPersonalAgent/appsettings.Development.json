{
  "Agent": {
    "StateDatabasePath": "data/state.sqlite",
    "WorkspacePath": "data/workspace",
    "MemoryRetrievalMode": "before_invoke",
    "CapsuleExtractionMode": "manual",
    "CapsuleAutoBatchRawEventThreshold": 20
  },
  "Llm": {
    "RouterMode": "off",
    "RouterSmallModel": "moonshot-v1-8k",
    "RouterMaxInputCharsForSmall": 1800,
    "RouterMaxHistoryMessagesForSmall": 10,
    "RouterDeepKeywords": "пошагово,step-by-step,deep reasoning"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
